# Project and server settings
COVFEE_PROJECT_FILE=getting_started.py
COVFEE_HOST=localhost
COVFEE_PUBLIC_PORT=5000
COVFEE_BIND_HOST=0.0.0.0
COVFEE_BIND_PORT=5000

# Auth and secrets
COVFEE_SECRET_KEY=change-me
COVFEE_ADMIN_USERNAME=admin
COVFEE_ADMIN_PASSWORD=change-me

# Media serving
COVFEE_MEDIA_SERVER=true
COVFEE_MEDIA_URL=

# SSL
COVFEE_SSL_CERT_FILE=
COVFEE_SSL_KEY_FILE=

# Docker image source
COVFEE_PIP_SPEC=git+https://github.com/josedvq/covfee.git
COVFEE_FORCE_REBUILD=false
